# Copy this file to .env and fill in the values. .env is gitignored.

# Slack credentials (from your app's "Basic Information" and "OAuth & Permissions" pages)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# HTTP port the app listens on. Your tunnel (cloudflared/ngrok) points here.
PORT=3999

# Absolute path to the single project directory the agent may read and write.
PROJECT_WORKSPACE=/path/to/your/project

# Model. Default is claude-sonnet-5. claude-opus-4-8 is the higher-quality upgrade.
CLAUDE_MODEL=claude-sonnet-5

# Optional: path to a custom system-prompt file. Defaults to ./prompt.md, falling
# back to a built-in default if that file does not exist. Editing it requires a restart.
# AGENT_PROMPT_FILE=./prompt.md

# Optional: which Claude settings layers the agent inherits (comma-separated).
# Default is "project,local". Add "user" to also inherit your personal global
# ~/.claude config and its MCP servers. Read the Security section before doing so.
# CLAUDE_SETTING_SOURCES=project,local

# Optional: allow MCP tools (Notion, Google Drive, etc.) to run. Off by default,
# so MCP tools are blocked by the permission gate until you set this. When on, MCP
# tools run automatically and are NOT covered by the plan-approval write gate, so
# only connect MCP servers you trust. See "Tips and tricks" in the README.
# ALLOW_MCP_TOOLS=true
